{
  "manifest_version": 3,
  "name": "Audio Downloader Companion",
  "version": "1.1.0",
  "description": "Standalone audio downloader with sequence and ZIP export.",
  "action": {
    "default_title": "Audio Downloader",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "downloads",
    "declarativeNetRequestWithHostAccess",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
